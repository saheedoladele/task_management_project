PORT=3001
NODE_ENV=development

# Option A: single URL (Render, Railway, etc.) — overrides DB_* below
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# DB_SSL=false   # only if you must disable TLS (rare)

# Option B: local Postgres (no DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=taskmanager

# Local dev: true auto-updates schema. Production: false and use npm run migration:run
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Comma-separated origins for CORS (optional). Empty = allow all in dev
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
