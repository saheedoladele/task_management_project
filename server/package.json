{
  "name": "task-manager-api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start:dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migration:run": "tsx ./node_modules/typeorm/cli.js migration:run -d ./src/config/data-source.ts",
    "migration:revert": "tsx ./node_modules/typeorm/cli.js migration:revert -d ./src/config/data-source.ts",
    "migration:show": "tsx ./node_modules/typeorm/cli.js migration:show -d ./src/config/data-source.ts",
    "migration:generate": "tsx ./node_modules/typeorm/cli.js migration:generate -d ./src/config/data-source.ts --esm",
    "migration:create": "tsx ./node_modules/typeorm/cli.js migration:create",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d ./dist/config/data-source.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.16.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
